generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(uuid())
  username  String    @unique
  email     String    @unique
  password  String
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novels      Novel[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Novel {
  id         String     @id @default(uuid())
  title      String
  genre      String?
  synopsis   String?
  projectId  String
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  characters Character[]
  chapters   Chapter[]
  worldSetting WorldSetting?
  outline     Outline?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Character {
  id          String   @id @default(uuid())
  name        String
  description String?
  personality String?
  appearance  String?
  background  String?
  novelId     String
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Chapter {
  id       String   @id @default(uuid())
  title    String
  content  String
  order    Int
  wordCount Int     @default(0)
  status   String   @default("draft")
  novelId  String
  novel    Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorldSetting {
  id               String   @id @default(uuid())
  name             String
  genre            String
  description      String
  timeSetting      String?
  locationSetting  String?
  socialStructure  String?
  culturalRules    String?
  magicOrTechSystem String?
  novelId          String   @unique
  novel            Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Outline {
  id              String   @id @default(uuid())
  title           String
  mainArc         String?
  subArcs         String?  // JSON array stored as string
  volumeStructure String?  // JSON array stored as string
  plotPoints      String?  // JSON array stored as string
  totalChapters   Int      @default(30)
  novelId         String   @unique
  novel           Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
